{
  "name": "next-boilerplate",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "author": {
    "name": "Cristian Giehl",
    "email": "cristiangiehl@gmail.com"
  },
  "scripts": {
    "dev": "trap \"pnpm run services:stop\" INT EXIT && pnpm run services:up && pnpm run services:wait:database && pnpm run migrations:up && next dev",
    "build": "next build",
    "start": "next start",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "services:up": "docker compose -f src/infra/compose.yaml up -d",
    "services:stop": "COMPOSE_INTERACTIVE_NO_CLI=1 docker compose -f ./src/infra/compose.yaml stop",
    "services:down": "docker compose -f ./src/infra/compose.yaml down",
    "services:wait:database": "tsx ./src/infra/scripts/wait-for-postgres.ts",
    "migrations:create": "node-pg-migrate -m './src/infra/migrations' create",
    "migrations:up": "node-pg-migrate -m './src/infra/migrations' up",
    "migrations:down": "node-pg-migrate -m './src/infra/migrations' down",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.91.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookie": "^1.1.1",
    "ky": "^1.14.3",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^10.0.3",
    "react-phone-number-input": "^3.4.16",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
